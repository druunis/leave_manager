# Copy to artifacts/api-server/.env and artifacts/leave-tracker/.env (or export before running).
# Get Clerk keys from https://dashboard.clerk.com — add http://localhost:5173 to allowed origins.

# --- API server (artifacts/api-server/.env) ---
PORT=8080
DATABASE_URL=postgresql://dk@localhost:5432/leave_manager
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
# LOG_LEVEL=info
# EMAIL_FROM="Leave Tracker <notifications@example.com>"

# --- Frontend (artifacts/leave-tracker/.env) ---
# PORT=5173
# BASE_PATH=/
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
# VITE_API_PROXY_TARGET=http://localhost:8080
